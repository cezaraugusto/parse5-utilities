{
  "name": "parse5-utilities",
  "description": "Low-level parse5 node manipulation utilities. ESM-compatible version of parse5-utils.",
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@9.9.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@rslib/core": "^0.9.1",
    "@types/node": "^22.15.21",
    "eslint": "^10.5.0",
    "eslint-config-auditor": "^2.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "dependencies": {
    "parse5": "^7.3.0"
  },
  "keywords": [
    "html",
    "parse5",
    "utilities",
    "ast"
  ],
  "bugs": "https://github.com/cezaraugusto/parse5-utilities/issues",
  "homepage": "https://github.com/cezaraugusto/parse5-utilities#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "provenance": true
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cezaraugusto/parse5-utilities.git"
  }
}
